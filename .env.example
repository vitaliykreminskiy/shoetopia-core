# Database
DATABASE_URL=postgresql://shoetopia:localdevpassword@localhost:5432/shoetopia
POSTGRES_PASSWORD=localdevpassword

# Redis
REDIS_URL=redis://localhost:6379

# Auth
# Bearer secret for ALL non-public API routes (health probes excepted).
# REQUIRED in production — when unset with NODE_ENV=production the API fails
# closed and returns 401 for every protected route. Must equal the shoetopia
# frontend's CORE_API_KEY (same shared secret on both sides).
# Generate with: openssl rand -hex 32
API_SECRET=change-me-in-production
ADMIN_SECRET=change-me-in-production

# FlexOffers
FLEXOFFERS_API_KEY=

# Node
NODE_ENV=development
